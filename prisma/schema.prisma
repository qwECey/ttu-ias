generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  COMPANY
  SUPERVISOR
  INDUSTRY_SUPERVISOR
  LIAISON
  ADMIN
}

enum ReportType {
  WEEKLY
  MONTHLY
  FINAL
}

enum ReportStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  loginId   String   @unique
  email     String?  @unique
  password  String
  role      UserRole
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student   Student?
  company   Company?
  //supervisor Supervisor?
  industrySupervisor IndustrySupervisor?

  @@map("users")
}

model Student {
  id            String @id @default(cuid())
  userId        String @unique

  studentId     String @unique
  fullName      String
  email         String? @unique
  phone         String?

  department    String
  programme     String
  level         Int

  placementStatus String @default("UNPLACED")

  companyId     String?

  user User @relation(fields: [userId], references: [id])

  company Company? @relation(fields: [companyId], references: [id])

  supervisorId String?

  supervisor Supervisor? @relation(fields: [supervisorId], references: [id])

  industrySupervisorId String? 

  industrySupervisor IndustrySupervisor? @relation(fields: [industrySupervisorId], references: [id])

  placements Placement[]

  reports Report[]

  @@map("students")
}

model Company {
  id            String @id @default(cuid())
  userId        String @unique

  companyName   String
  location      String

  contactPerson String
  contactPhone  String

  approved      Boolean @default(false)

  user User @relation(fields: [userId], references: [id])

  students Student[]

  placements Placement[]

  industrySupervisors IndustrySupervisor[]

  @@map("companies")
}

model IndustrySupervisor {
  id String @id @default(cuid())

  fullName String

  email String @unique

  phone String?

  companyId String

  company Company @relation(fields: [companyId], references: [id])

  userId String @unique

  user User @relation(fields: [userId], references: [id])

  students Student[]

  @@map("industry_supervisors")
}

model Supervisor {
  id        String @id @default(cuid())

  fullName  String
  email     String @unique
  phone     String?

  students Student[]

  @@map("supervisors")
}

model Placement {
  id         String   @id @default(cuid())

  studentId  String
  companyId  String

  assignedAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])

  company Company @relation(fields: [companyId], references: [id])

  @@map("placements")
}

model Report {
  id String @id @default(cuid())

  studentId String

  title String

  reportType ReportType

  periodNumber Int?

  content String

  fileUrl String?

  status ReportStatus @default(PENDING)

  supervisorRemarks String?

  approvedAt DateTime?

  submittedAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])

  @@map("reports")
}