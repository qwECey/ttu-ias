generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  COMPANY
  SUPERVISOR
  LIAISON
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  loginId   String   @unique
  email     String?  @unique
  password  String
  role      UserRole
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student   Student?
  company   Company?

  @@map("users")
}

model Student {
  id            String @id @default(cuid())
  userId        String @unique

  studentId     String @unique
  fullName      String
  email         String? @unique
  phone         String?

  department    String
  programme     String
  level         Int

  placementStatus String @default("UNPLACED")

  user User @relation(fields: [userId], references: [id])

  @@map("students")
}

model Company {
  id            String @id @default(cuid())
  userId        String @unique

  companyName   String
  location      String

  contactPerson String
  contactPhone  String

  approved      Boolean @default(false)

  user User @relation(fields: [userId], references: [id])

  @@map("companies")
}